# Copy this file to .env for local development.
# Do not commit .env or real secrets.

# All defaults resolve outside the tracked repository. Override these with
# absolute paths appropriate for the host.
CLOUDA_RUNTIME_ROOT=
CLOUDA_DATASET_ROOT=
CLOUDA_ARTIFACT_ROOT=
CLOUDA_MODEL_ROOT=
CLOUDA_CACHE_ROOT=
CLOUDA_DATABASE_PATH=
CLOUDA_DATASET_MANIFEST_DATABASE_PATH=
CLOUDA_LOCAL_OCR_ENABLED=false
CLOUDA_MAX_UPLOAD_BYTES=104857600
CLOUDA_MAX_RESULT_BYTES=104857600
CLOUDA_MAX_PDF_BYTES=104857600
CLOUDA_MAX_PDF_PAGES=500
CLOUDA_MAX_IMAGE_PIXELS=40000000
CLOUDA_MAX_ARCHIVE_MEMBERS=10000
CLOUDA_MAX_DECOMPRESSED_BYTES=1073741824
CLOUDA_ALLOWED_HOSTS=127.0.0.1,localhost
CLOUDA_USER_DOCUMENT_TRAINING_CONSENT=false
# Optional only during a controlled worker-key rotation; remove after cutover.
CLOUDA_WORKER_API_KEY_PREVIOUS=

APP_ROLE=server
LOCAL_PROCESSING_ENABLED=true
SERVER_BASE_URL=http://127.0.0.1:8000
REDIS_URL=redis://127.0.0.1:6379/0
RQ_QUEUE_NAME=pdf_conversion
WORKER_API_KEY=
WORKER_NAME=clouda-local
WORKER_CONCURRENCY=1

DATABASE_PATH=data/clouda.sqlite3
STORAGE_ROOT=conversions
TEMP_ROOT=conversions/temporary
JOB_TIMEOUT_SECONDS=7200
JOB_RETRY_COUNT=2

# Optional cloud/provider variables for future non-default integrations.
# No OCR model is selected or claimed as supported yet.
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
