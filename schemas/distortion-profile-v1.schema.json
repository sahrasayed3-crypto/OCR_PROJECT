{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Clouda distortion profile v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "profile_id", "schema_version", "description", "intended_use", "severity",
    "random_seed_policy", "transformations", "parameter_ranges", "probabilities",
    "exclusions", "maximum_output_dimensions", "expected_output_count_per_source_page",
    "license_restrictions", "quality_class_label"
  ],
  "properties": {
    "profile_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]+$"},
    "schema_version": {"const": 1},
    "description": {"type": "string", "minLength": 3},
    "intended_use": {"type": "string", "minLength": 3},
    "severity": {"enum": ["minimal", "light", "medium", "heavy", "extreme"]},
    "random_seed_policy": {"enum": ["required_deterministic"]},
    "transformations": {
      "type": "array", "minItems": 1, "maxItems": 32,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "probability", "severity"],
        "properties": {
          "name": {"type": "string"},
          "probability": {"type": "number", "minimum": 0, "maximum": 1},
          "severity": {"enum": ["minimal", "light", "medium", "heavy", "extreme"]},
          "parameters": {"type": "object"}
        }
      }
    },
    "parameter_ranges": {"type": "object"},
    "probabilities": {"type": "object"},
    "exclusions": {"type": "array", "items": {"type": "string"}},
    "maximum_output_dimensions": {
      "type": "array", "prefixItems": [{"type":"integer","minimum":256},{"type":"integer","minimum":256}],
      "minItems": 2, "maxItems": 2
    },
    "expected_output_count_per_source_page": {"type": "integer", "minimum": 1, "maximum": 20},
    "license_restrictions": {"type": "string"},
    "quality_class_label": {"enum": ["easy", "medium", "difficult", "extreme", "control"]}
  }
}
