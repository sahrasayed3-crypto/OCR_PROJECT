{
  "name": "mixed_layout",
  "recommended_use": "Arabic-English, tables, columns, and varied text zones.",
  "distortions": [
    {"name": "gaussian_noise", "probability": 0.45, "severity": "medium", "parameters": {"low_priority_regions": true}},
    {"name": "partial_clipping", "probability": 0.18, "severity": "light", "parameters": {"avoid_regions": ["title", "page_number"]}},
    {"name": "scanner_noise", "probability": 0.35, "severity": "light", "parameters": {"amount": [0.01, 0.03]}}
  ],
  "ordering_constraints": ["layout-aware operations after region masks are loaded"],
  "mutually_exclusive": [["partial_clipping", "cropping"]],
  "maximum_allowed_crop": 0.015,
  "minimum_readable_text_threshold": 0.93,
  "metadata_fields": ["layout_metadata", "operation_order", "parameters", "random_seed"]
}
