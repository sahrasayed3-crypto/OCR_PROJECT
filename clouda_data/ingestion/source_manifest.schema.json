{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.example/arabic-ocr/source-manifest.schema.json",
  "title": "Arabic OCR Source Ingestion Manifest",
  "type": "object",
  "required": ["documents", "pages"],
  "properties": {
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["document_id", "source_path", "source_type"],
        "properties": {
          "document_id": {"type": "string", "minLength": 1},
          "source_path": {"type": "string", "minLength": 1},
          "source_type": {
            "type": "string",
            "enum": ["pdf", "docx", "image", "text", "json_layout", "page_xml", "alto_xml", "ground_truth_json"]
          },
          "language": {"type": "string"},
          "source_license": {"type": "string"},
          "title": {"type": ["string", "null"]}
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["document_id", "page_id", "page_number", "source_path", "source_type"],
        "properties": {
          "document_id": {"type": "string", "minLength": 1},
          "page_id": {"type": "string", "minLength": 1},
          "page_number": {"type": "integer", "minimum": 1},
          "source_path": {"type": "string", "minLength": 1},
          "source_type": {
            "type": "string",
            "enum": ["pdf", "docx", "image", "text", "json_layout", "page_xml", "alto_xml", "ground_truth_json"]
          },
          "language": {"type": "string"},
          "ground_truth_path": {"type": ["string", "null"]},
          "clean_text": {"type": ["string", "null"]},
          "text_checksum": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
          "layout_path": {"type": ["string", "null"]},
          "source_license": {"type": "string"},
          "reading_order": {"type": "array", "items": {"type": "string"}}
        },
        "anyOf": [
          {"required": ["ground_truth_path"]},
          {"required": ["clean_text"]}
        ]
      }
    }
  }
}
