OPENROUTER_API_KEY=
CLOUDA_PORT=8501
CLOUDA_BIND_ADDRESS=127.0.0.1
CLOUDA_API_BIND_ADDRESS=127.0.0.1
CLOUDA_ALLOW_PUBLIC_BIND=false
CLOUDA_EXTERNAL_AUTH_ENFORCED=false
CLOUDA_PROJECT_DIR=/opt/clouda
